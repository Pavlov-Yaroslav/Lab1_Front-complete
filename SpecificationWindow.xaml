<Window x:Class="Lab1_Front.SpecificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Спецификация" Height="600" Width="600">

    <DockPanel>

        <!-- Верхнее дерево -->
        <TreeView x:Name="SpecTreeView" DockPanel.Dock="Top" Margin="5" />

        <!-- Нижняя панель с кнопками -->
        <StackPanel DockPanel.Dock="Bottom" 
            Orientation="Vertical"
            VerticalAlignment="Center"
            HorizontalAlignment="Center" 
            Margin="5">
            <Button Content="Удалить окончательно (Сжать)" 
            Click="BtnTruncate_Click" 
            Width="180" Height="30"
            Margin="5"/>
            <Button Content="Восстановить запись" 
            Click="BtnRestore_Click" 
            Width="150" Height="30"
            Margin="5"/>
        </StackPanel>
    </DockPanel>

    <!-- Контекстное меню -->
    <Window.Resources>
        <ContextMenu x:Key="TreeContextMenu">
            <MenuItem Header="Добавить" Click="MenuItem_Add_Click"/>
            <MenuItem Header="Изменить" Click="MenuItem_Edit_Click"/>
            <MenuItem Header="Удалить" Click="MenuItem_Delete_Click"/>
        </ContextMenu>
    </Window.Resources>
</Window>