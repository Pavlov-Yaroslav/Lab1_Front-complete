<Window x:Class="Lab1_Front.ComponentsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Компоненты" Height="600" Width="600">

    <Window.Resources>
        <!-- Стиль для удаленных строк -->
        <Style x:Key="DeletedRowStyle" TargetType="DataGridRow">
            <Setter Property="Foreground" Value="Black"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                    <Setter Property="Foreground" Value="Gray"/>
                    <Setter Property="FontStyle" Value="Italic"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Верхняя панель кнопок -->
        <ToolBar DockPanel.Dock="Top">
            <Button Content="Добавить" Width="80" Click="AddButton_Click"/>
            <Button Content="Удалить" Width="80" Click="DeleteButton_Click"/>
            <Button Content="Восстановить" Width="80" Click="RestoreButton_Click"/>
            <Button Content="Восстановить все" Click="RestoreAllButton_Click" Width="120" Height="30"/>
            <Button Content="Сжать" Width="80" Click="TruncateButton_Click"/>
        </ToolBar>

        <!-- Нижняя панель для ввода -->
        <Grid DockPanel.Dock="Bottom" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Наименование:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="NameTextBox" Grid.Column="1" Margin="0,0,10,0"/>
            <TextBlock Grid.Column="3" Text="Тип:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox x:Name="TypeTextBox" Grid.Column="4">
                <ComboBoxItem Content="Деталь"/>
                <ComboBoxItem Content="Узел"/>
                <ComboBoxItem Content="Изделие"/>
            </ComboBox>
        </Grid>

        <DataGrid x:Name="ComponentsGrid" 
                  AutoGenerateColumns="False" 
                  Margin="5" 
                  CanUserAddRows="False" 
                  IsReadOnly="True"
                  SelectionMode="Single" 
                  SelectionUnit="FullRow"
                  RowStyle="{StaticResource DeletedRowStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
        <ComboBox Width="100"/>
    </DockPanel>
</Window>